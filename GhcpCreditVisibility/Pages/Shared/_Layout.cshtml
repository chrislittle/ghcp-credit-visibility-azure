@using GhcpCreditVisibility.Authorization
@using GhcpCreditVisibility.Services
@inject IAppAdminChecker AdminChecker
@inject AdminMappingService AppSettings
@{
    var orgName = await AppSettings.GetSettingAsync(AdminMappingService.OrgDisplayNameKey);
    var hasOrg = !string.IsNullOrWhiteSpace(orgName);
    var isAdmin = User?.Identity?.IsAuthenticated == true && await AdminChecker.IsAdminAsync(User);
    var currentPage = (ViewContext.RouteData.Values["page"] as string) ?? "";
    string Active(string page) => currentPage.Equals(page, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    // Avatar initials from the signed-in identity.
    var who = User?.Identity?.Name ?? "";
    var parts = who.Split(new[] { ' ', '@', '.' }, StringSplitOptions.RemoveEmptyEntries);
    var initials = parts.Length switch
    {
        0 => "··",
        1 => (parts[0].Length >= 2 ? parts[0].Substring(0, 2) : parts[0]).ToUpperInvariant(),
        _ => $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @(hasOrg ? orgName : "GitHub Copilot Credit Visibility")</title>
    <meta name="description" content="GitHub Copilot AI-credit usage reporting across the enterprise, by user and cost center." />
    <meta name="theme-color" content="#1e293b" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GhcpCreditVisibility.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="gh-topbar">
        <a class="gh-brand" asp-area="" asp-page="/Index">
            <span class="gh-logo" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
            </span>
            <span>GitHub Copilot Credit Visibility</span>
        </a>
        <nav class="gh-nav">
            <a class="@Active("/Index")" asp-area="" asp-page="/Index">Usage</a>
            <a class="@Active("/Reports")" asp-area="" asp-page="/Reports">Reports</a>
            @if (isAdmin)
            {
                <a class="@Active("/Admin/Mappings")" asp-area="" asp-page="/Admin/Mappings">Admin</a>
            }
            <a class="@Active("/About")" asp-area="" asp-page="/About">About</a>
        </nav>
        <div class="gh-right">
            @if (hasOrg)
            {
                <span>@orgName</span>
            }
            <span class="gh-avatar" title="@who">@initials</span>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a class="gh-signout" href="/.auth/logout?post_logout_redirect_uri=/" title="Sign out of @who">Sign out</a>
            }
        </div>
    </header>
    <div class="gh-wrap">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="gh-wrap py-2">
            &copy; 2026 · GitHub Copilot Credit Visibility · <a asp-area="" asp-page="/About">About</a> · <span class="text-muted">v@(GhcpCreditVisibility.AppInfo.Version)</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
